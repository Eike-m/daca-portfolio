--Harjutus 1B
--Kirjuta ise päring, mis ühendab sales ja products tabelid, et näha tootenimesid koos müüdud kogusega
SELECT
    p.product_name,
    p.category,
    s.quantity,
    s.unit_price
FROM sales s
INNER JOIN products p ON s.product_id = p.product_id
ORDER BY s.quantity DESC
LIMIT 15;

--selgitus:
p.product_name → toote nimi tuleb products tabelist
s.quantity → müüdud kogus tuleb sales tabelist
INNER JOIN → ühendab tabelid product_id järgi
ORDER BY s.quantity DESC → suurim kogus ees
LIMIT 15 → ainult 15 rida

