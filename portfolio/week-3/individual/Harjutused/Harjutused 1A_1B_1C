--Harjutus 1C: Mõtle ühele küsimusele, millele INNER JOIN aitab vastata. Kirjuta päring ja vaata tulemust.
--Ideed:
--Millised kliendid tellisid viimase kuu jooksul?
--Milliste toodete tellimustes on kõrgeim ühikuhind?
--Millistest linnadest tulevad tellimused? --Tallinn 3601 tellimust, Tartu 1764 tellimust, Pärnu 1231 tellimust
SELECT 
    c.city AS linn, 
    COUNT(s.sale_id) AS tellimuste_arv, 
    SUM(s.total_price) AS kogukäive
FROM sales s
INNER JOIN customers c ON s.customer_id = c.customer_id
GROUP BY c.city
ORDER BY kogukäive DESC;

Milliste toodete tellimustes on kõrgeim ühikuhind? - kõrgeim hind on klassikaline seemisnahkne jooksutoss, 512,37
SELECT DISTINCT 
    p.product_name AS toode, 
    s.unit_price AS ühikuhind,
    p.category AS kategooria
FROM sales s
INNER JOIN products p ON s.product_id = p.product_id
ORDER BY s.unit_price DESC
LIMIT 10;