--Harjutus 2C: Rakendus — kadunud klientide analüüs 
--Ülesanne: Anna tahab teada rohkem kadunud klientide kohta.
--Kirjuta päring, mis grupeerib kadunud kliendid linnade kaupa ja näitab, mitu kadunud klienti on igas linnas.
SELECT 
    c.city AS linn, 
    COUNT(c.customer_id) AS kadunud_klientide_arv
FROM customers c
LEFT JOIN sales s ON c.customer_id = s.customer_id
WHERE s.sale_id IS NULL
GROUP BY c.city
ORDER BY kadunud_klientide_arv DESC;
