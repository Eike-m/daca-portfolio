--Ülesanne: Mõtle äriküsimusele, mis vajab 3+ tabeli ühendamist. Kirjuta päring ja analüüsi tulemust.
--Ideed:
--Millised kliendid ostavad kõige kallimaid tooteid? Kersti Lill, kogumüük 14303,29; Tiina Pärn 13393,98
SELECT 
    customers.first_name,
    customers.last_name,
    SUM(products.retail_price) AS kogumüük
FROM customers
INNER JOIN sales 
    ON customers.customer_id = sales.customer_id
INNER JOIN products 
    ON sales.product_id = products.product_id
GROUP BY customers.first_name, customers.last_name
ORDER BY kogumüük DESC;
--Millised kategooriad on populaarsed eri linnades? Haapsalu - meeste riided, Jõhvi - laste riided, Kuressaare naiste riided
SELECT 
    customers.city,
    products.category,
    COUNT(sales.sale_id) AS total_orders
FROM customers
INNER JOIN sales 
    ON customers.customer_id = sales.customer_id
INNER JOIN products 
    ON sales.product_id = products.product_id
GROUP BY customers.city, products.category
ORDER BY customers.city, total_orders DESC;

--Millised tellimused sisaldavad enim erinevaid tooteid?
SELECT 
    customers.first_name,
    customers.last_name,
    sales.sale_id,
    COUNT(DISTINCT products.product_id) AS unique_products
FROM customers
INNER JOIN sales 
    ON customers.customer_id = sales.customer_id
INNER JOIN products 
    ON sales.product_id = products.product_id
GROUP BY customers.first_name, customers.last_name, sales.sale_id
ORDER BY unique_products DESC;