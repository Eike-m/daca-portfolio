--Harjutus 3B:
--Ülesanne: Anna tahab teada: "Millised tootekategooriad müüvad igas linnas kõige rohkem?" 
--Kirjuta ise päring, mis ühendab 3+ tabelit ja grupeerib tulemused.
--Vihjed:
Ühenda sales + customers + products
Grupeeri city ja category järgi
Arvuta SUM(s.total_price) kogumüügi jaoks
Sorteeri kahanevalt
SELECT
    p.category,
    c.city,
    sum(s.total_price) AS kogumüük
FROM sales s
INNER JOIN customers c ON s.customer_id = c.customer_id
INNER JOIN products p ON s.product_id = p.product_id
group by c.city, p.category
ORDER BY kogumüük DESC

