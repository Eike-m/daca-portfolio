--Ülesanne: Mõtle äriküsimusele, millele GROUP BY aitab vastata. Kirjuta päring ja analüüsi tulemust.
--Ideed:
--Müük nädalapäevade kaupa (millal ostetakse enim?) --Enim on ostetud pühapäeval, kogukäive 437716.54, 1444 tellimust
SELECT
  TO_CHAR(sale_date, 'FMDay') AS nadalapaev,      --FM eemaldab liigsed tühikud
  COUNT(*) AS tellimuste_arv,                     --mitu rida/tellimust igas grupis
  SUM(total_price) AS kogukaive,
  ROUND(AVG(total_price), 2) AS keskmine_tellimus  --round ümardab 2 komakohani
FROM sales
GROUP BY
  EXTRACT(ISODOW FROM sale_date),                  --jagab andmed gruppidesse, iga nädalapäev on eraldi grupp
  TO_CHAR(sale_date, 'FMDay')
ORDER BY EXTRACT(ISODOW FROM sale_date);
--Toodete arv kategooriate kaupa   --meeste riided 82 tk, jalanõud 73
