--Harjutus 2A: Shu — järgi malli 
--Ülesanne: Kopeeri ja käivita — leia kliendid, kes on ostnud üle 500€:
SELECT
    c.customer_id,
    c.first_name || ' ' || c.last_name AS nimi,
    COUNT(s.sale_id) AS tellimuste_arv,
    SUM(s.total_price) AS kogukäive
FROM customers c
JOIN sales s ON c.customer_id = s.customer_id
GROUP BY c.customer_id, c.first_name, c.last_name
HAVING SUM(s.total_price) > 500
ORDER BY kogukäive DESC;

--Mitu klienti ületas 500€ piiri? 1722 klienti
--Kes on TOP 3 klienti? Tiina Pärn, Priit Rand, Kevin Org
--Kui muudad piiri 1000€ peale, mitu jääb? 936 klienti

--Harjutus 2B: Ha — Liisi varude audit 
--Ülesanne: Liis Koppel helistas, sest Tartu poe varudes on erinevused. Kirjuta päring, mis leiab tooted, kus kategoorias on müüdud üle vali ise piir] ühiku.
--Vihjed:
--Ühenda products ja sales
--Grupeeri category järgi
--Kasuta SUM(quantity) müüdud koguse jaoks
--HAVING: filtreeri kategooriad, kus müüdud kogus ületab sinu valitud piiri
--Lisa ka AVG(price) ja COUNT(DISTINCT product_id)
--Kirjuta oma päring siia:
SELECT
  p.category,
  SUM(s.quantity) AS kogumyyk,
  round(AVG(p.retail_price), 2) AS keskmine_hind,       
  COUNT(DISTINCT p.product_id) AS toodete_arv
FROM products p
JOIN sales s
  ON p.product_id = s.product_id
WHERE s.store_location = 'Tartu'
GROUP BY p.category
HAVING SUM(s.quantity) > 100
ORDER BY kogumyyk DESC;

--Milline kategooria müüb kõige rohkem ühikuid? meeste riided, toodete arv 81
--Milline on kõige kõrgema keskmise hinnaga kategooria? jalanõud, keskmine hind 214,94
--Kas kallim kategooria müüb ka rohkem? Miks / miks mitte? Jah, kogumüük on 732 ühikut ja toodete arv 81

--Harjutus 2C: Rakendus — WHERE + HAVING koos 
--Ülesanne: Kirjuta päring, mis kasutab NII WHERE-d KUI KA HAVING-ut koos.
--Mõtle äriküsimusele, kus sul on vaja filtreerida nii üksikuid ridu kui ka gruppe.
--Näide äriküsimusest: "Näita ainult 2024. aasta Q1 tellimused (WHERE), grupeerituna kuu kaupa, kus käive on üle 5000€ (HAVING)."
SELECT
  DATE_TRUNC('month', sale_date) AS kuu,
  SUM(total_price) AS kogukaive,
  COUNT(*) AS tellimuste_arv
FROM sales
WHERE sale_date >= DATE '2024-01-01'          --võtab ainult Q1 kuud
  AND sale_date < DATE '2024-04-01'
GROUP BY DATE_TRUNC('month', sale_date)       --teeb igast kuust ühe grupi
HAVING SUM(total_price) > 5000
ORDER BY kuu;
