--Harjutus 3C: Rakendus — Window Function 
--Ülesanne: Kasuta ROW_NUMBER() funktsiooni, et leida iga kategooria TOP 3 toodet müüdud koguse järgi.
--Vihjed:
--Ühenda products ja sales
--CTE-s: grupeeri category + product_name järgi, arvuta SUM(quantity)
--Lisa ROW_NUMBER() OVER (PARTITION BY category ORDER BY SUM(quantity) DESC)
--Põhipäringus: filtreeri WHERE koht <= 3
WITH product_sales AS (                                             --kasutatud AI abi!
    SELECT
        p.category,
        p.product_name,
        SUM(s.quantity) AS kogus
    FROM products p
    JOIN sales s
      ON p.product_id = s.product_id
    GROUP BY p.category, p.product_name
),

ranked_products AS (
    SELECT
        category,
        product_name,
        kogus,
        ROW_NUMBER() OVER (                      --positsioon
            PARTITION BY category                --grupp
            ORDER BY kogus DESC
        ) AS rn
    FROM product_sales
)

SELECT
    category,
    product_name,
    kogus
FROM ranked_products
WHERE rn <= 3                        --top 3 toodet jätab alles igas kategoorias
ORDER BY category, rn;


--Integreeriv harjutus — CEO Raport 
--Ülesanne: Kirjuta üks CTE-põhine päring, mis annab Kristile ülevaate TOP 5 linnast koos igakuise trendiga.
--Struktuur:
WITH linna_myyk AS (                    
    -- CTE 1: iga linna kogumüük
    SELECT
        c.city AS linn,
        COUNT(DISTINCT s.sale_id) AS tellimusi,
        SUM(s.total_price) AS kogukaive,
        ROUND(AVG(s.total_price), 2) AS keskmine_tellimus
    FROM customers c
    JOIN sales s ON c.customer_id = s.customer_id
    WHERE s.sale_date >= '2024-01-01'
    GROUP BY c.city
    HAVING COUNT(DISTINCT s.sale_id) > 5  -- Filtreeri välja väikesed linnad
),
linna_jarjestus AS (
    -- CTE 2: lisa järjestus
    SELECT
        linn,
        tellimusi,
        kogukaive,
        keskmine_tellimus,
        ROW_NUMBER() OVER (ORDER BY kogukaive DESC) AS koht
    FROM linna_myyk
)
SELECT *
FROM linna_jarjestus
WHERE koht <= 5
ORDER BY koht;

--Kui see töötab, proovi lisada:                                    --kasutatud AI abi!
Iga linna osakaal kogu käibest (protsentides)
