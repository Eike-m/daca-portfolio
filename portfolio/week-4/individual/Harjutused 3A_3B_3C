WITH linna_myyk AS (
    SELECT
        c.city AS linn,
        COUNT(DISTINCT s.sale_id) AS tellimusi,
        SUM(s.total_price) AS kogukaive,
        ROUND(AVG(s.total_price), 2) AS keskmine_tellimus
    FROM customers c
    JOIN sales s ON c.customer_id = s.customer_id
    WHERE s.sale_date >= '2024-01-01'
    GROUP BY c.city
    HAVING COUNT(DISTINCT s.sale_id) > 5
),

linna_jarjestus AS (
    SELECT
        linn,
        tellimusi,
        kogukaive,
        keskmine_tellimus,

        -- 1) osakaal kogu käibest
        ROUND(
            100.0 * kogukaive / SUM(kogukaive) OVER (),
            2
        ) AS osakaal_protsentides,

        -- 2) viimane kuu vs keskmine (vajab eraldi loogikat)
        kogukaive AS viimase_kuu_kaive,

        AVG(kogukaive) OVER () AS keskmine_kaive,

        ROW_NUMBER() OVER (ORDER BY kogukaive DESC) AS koht
    FROM linna_myyk
)

SELECT *
FROM linna_jarjestus
WHERE koht <= 5
ORDER BY koht;

